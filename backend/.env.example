# Copy this file to .env and fill in your API keys
# Never commit .env to version control

FLASK_ENV=development

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# AlienVault OTX — https://otx.alienvault.com/api
ALIENVAULT_API_KEY=your_alienvault_key_here

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# Dashboard API key — callers must send this in the X-API-Key header
DASHBOARD_API_KEY=change_me_to_a_long_random_secret

# Allowed CORS origin — set to your portfolio URL in production
# CORS_ORIGIN=https://yourportfolio.com

# Redis (production onlyleave empty for development)
# REDIS_URL=redis://localhost:6379/0

# SOAR webhook — Slack-compatible URL for incident alerts (its optional)
# WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
